{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "CallbackPath": "/signin-oidc"
  },
  "ConnectionStrings": {
    "Default": "Server=localhost,1433;Database=TimeLogger;User Id=sa;Password=<your-db-password>;TrustServerCertificate=True"
  },
  "Timelog": {
    "BaseUrl": "https://app2.timelog.com/<tenant>/api",
    "ApiKey": "<your-timelog-api-key>"
  },
  "Tempo": {
    "BaseUrl": "https://api.tempo.io/4"
  },
  "Jira": {
    "BaseUrl": "https://<your-org>.atlassian.net",
    "Email": "<your-atlassian-email>",
    "ApiToken": "<your-jira-api-token>"
  },
  "Mapping": {
    "TimelogAccountFieldKey": "",
    "OvertimeAttributeKey": "attr__Overtime_"
  },
  "Hangfire": {
    "DailyPullCron": "0 6 * * *",
    "DashboardUser": "admin",
    "DashboardPassword": ""
  },
  "JobHealth": {
    "ConsecutiveFailureThreshold": 3
  },
  "Notifications": {
    "SlackWebhookUrl": "",
    "EmailTo": "",
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpFrom": "",
    "SmtpUser": "",
    "SmtpPassword": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
