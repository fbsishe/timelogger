@inherits LayoutComponentBase
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthStateProvider
@implements IAsyncDisposable

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(_ => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="ml-3">TimeLogger</MudText>
        <MudSpacer />
        @if (_unmappedCount > 0)
        {
            <MudBadge Content="@_unmappedCount" Color="Color.Error" Overlap="true">
                <MudIconButton Icon="@Icons.Material.Filled.Warning" Color="Color.Warning"
                               Href="/entries" />
            </MudBadge>
        }
        @if (_currentUser is not null)
        {
            <MudText Typo="Typo.body2" Class="ml-2 mr-1">@_currentUser.DisplayName</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Class="mr-2">@_currentUser.Role</MudChip>
        }
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               Href="/MicrosoftIdentity/Account/SignOut" title="Sign out" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
            <AuthorizeView Policy="ManagerPlus">
                <MudNavLink Href="/mapping-rules" Icon="@Icons.Material.Filled.Rule"
                            IconColor="@(_staleRulesCount > 0 ? Color.Warning : Color.Inherit)">
                    Mapping Rules
                    @if (_staleRulesCount > 0)
                    {
                        <MudTooltip Text="@($"{_staleRulesCount} rule{(_staleRulesCount == 1 ? "" : "s")} point to an inactive Timelog project")">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning"
                                     Size="Size.Small" Class="ml-1" Style="vertical-align:middle" />
                        </MudTooltip>
                    }
                </MudNavLink>
                <MudNavLink Href="/employee-mappings" Icon="@Icons.Material.Filled.PeopleAlt">
                    Employee Mappings
                </MudNavLink>
            </AuthorizeView>
            <MudNavLink Href="/entries" Icon="@Icons.Material.Filled.List">
                Entries
                @if (_unmappedCount > 0)
                {
                    <MudBadge Content="@_unmappedCount" Color="Color.Error" Class="ml-2" />
                }
            </MudNavLink>
            <AuthorizeView Policy="ManagerPlus">
                <MudNavLink Href="/import-history" Icon="@Icons.Material.Filled.History">
                    Import History
                </MudNavLink>
                <MudNavLink Href="/upload" Icon="@Icons.Material.Filled.UploadFile">
                    File Upload
                </MudNavLink>
            </AuthorizeView>
            <AuthorizeView Policy="AdminOnly">
                <MudNavLink Href="/sources" Icon="@Icons.Material.Filled.Source">
                    Import Sources
                </MudNavLink>
                <MudNavLink Href="/timelog-sync" Icon="@Icons.Material.Filled.Sync">
                    Timelog Sync
                </MudNavLink>
            </AuthorizeView>
            <MudNavLink Href="/submission" Icon="@Icons.Material.Filled.Send">
                Submission
            </MudNavLink>
            <AuthorizeView Policy="AdminOnly">
                <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
                    Settings
                </MudNavLink>
                <MudNavLink Href="/users" Icon="@Icons.Material.Filled.ManageAccounts">
                    User Management
                </MudNavLink>
                <MudNavLink Href="/hangfire" Icon="@Icons.Material.Filled.Schedule">
                    Hangfire
                </MudNavLink>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4 px-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private int _unmappedCount;
    private int _staleRulesCount;
    private AppUser? _currentUser;
    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        await EnsureCurrentUserAsync();
        await RefreshBadgeAsync();
        _ = RunPeriodicRefreshAsync(_cts.Token);
    }

    private async Task EnsureCurrentUserAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true) return;

        var oid = authState.User.FindFirst("oid")?.Value
            ?? authState.User.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value
            ?? "";
        var email = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
        var name = authState.User.Identity.Name ?? "";

        if (string.IsNullOrEmpty(oid)) return;

        await using var scope = ScopeFactory.CreateAsyncScope();
        var userSvc = scope.ServiceProvider.GetRequiredService<IAppUserService>();
        _currentUser = await userSvc.EnsureUserAsync(oid, email, name);
    }

    private async Task RunPeriodicRefreshAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        while (await timer.WaitForNextTickAsync(ct))
        {
            await RefreshBadgeAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshBadgeAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var entrySvc = scope.ServiceProvider.GetRequiredService<IEntryService>();
        _unmappedCount = await entrySvc.GetUnmappedCountAsync();
        var ruleSvc = scope.ServiceProvider.GetRequiredService<IMappingRuleService>();
        var rules = await ruleSvc.GetAllAsync();
        _staleRulesCount = rules.Count(r => !r.IsProjectActive);
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
