@page "/submission"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AnyUser")]
@inject ISubmissionService SubmissionService
@inject ITimelogDataService TimelogDataService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IAppUserService AppUserService

<PageTitle>Submission – TimeLogger</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Submission Pipeline</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    @* Stats row *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Ready to Submit</MudText>
                <MudText Typo="Typo.h4"
                         Color="@(_readyEntries.Count > 0 ? Color.Info : Color.Default)">
                    @_readyEntries.Count
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Mapped entries with a Timelog task assigned
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Needs Task</MudText>
                <MudText Typo="Typo.h4"
                         Color="@(_needsTaskEntries.Count > 0 ? Color.Warning : Color.Default)">
                    @_needsTaskEntries.Count
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Mapped but no Timelog task assigned
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Submitted</MudText>
                <MudText Typo="Typo.h4" Color="Color.Success">@_submittedCount</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Total all-time</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Conflicts</MudText>
                <MudText Typo="Typo.h4"
                         Color="@(_conflictEntries.Count > 0 ? Color.Warning : Color.Default)">
                    @_conflictEntries.Count
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Hours differ from Timelog
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Failed</MudText>
                <MudText Typo="Typo.h4"
                         Color="@(_failedCount > 0 ? Color.Error : Color.Default)">
                    @_failedCount
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Submission attempts</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Action bar *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Send"
                   OnClick="SubmitSelectedAsync"
                   Disabled="@(_submitting || !_selectedEntries.Any())">
            @(_submitting ? "Submitting…" : $"Submit Selected ({_selectedEntries.Count})")
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.DoneAll"
                   OnClick="SubmitAllAsync"
                   Disabled="@(_submitting || _readyEntries.Count == 0)">
            @(_submitting ? "Submitting…" : $"Submit All ({_readyEntries.Count})")
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                   StartIcon="@Icons.Material.Filled.Block"
                   OnClick="SkipSelectedAsync"
                   Disabled="@(_submitting || !_selectedEntries.Any())">
            Skip Selected (@_selectedEntries.Count)
        </MudButton>
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadAsync">
            Refresh
        </MudButton>
        @if (_failedCount > 0)
        {
            <MudButton Variant="Variant.Text" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.CheckCircleOutline"
                       OnClick="AcknowledgeAllAsync">
                Clear @_failedCount failure@(_failedCount == 1 ? "" : "s")
            </MudButton>
        }
        @if (_submitting)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
        }
    </MudStack>

    @* Filter bar *@
    <MudPaper Elevation="0" Class="mb-4 pa-3" Style="background:var(--mud-palette-background-grey)">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" Color="Color.Secondary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">View entries for:</MudText>
            <MudSelect T="string?"
                       Value="_accountIdFilter"
                       ValueChanged="OnEmployeeFilterChanged"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Dense="true"
                       Style="min-width:220px"
                       AnchorOrigin="Origin.BottomLeft">
                <MudSelectItem T="string?" Value="@((string?)null)">All employees</MudSelectItem>
                @if (_myAccountId is not null)
                {
                    <MudSelectItem T="string?" Value="@_myAccountId">
                        Me — @(_employees.FirstOrDefault(e => e.AccountId == _myAccountId)?.DisplayName ?? _myAccountId)
                    </MudSelectItem>
                }
                @foreach (var emp in _employees.Where(e => e.AccountId != _myAccountId))
                {
                    <MudSelectItem T="string?" Value="@emp.AccountId">@emp.DisplayName</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </MudPaper>

    @* Conflicting entries section *@
    @if (_conflictEntries.Count > 0)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            @_conflictEntries.Count entr@(_conflictEntries.Count == 1 ? "y has" : "ies have") hours that differ from what is already registered in Timelog.
            Choose a resolution for each entry below.
        </MudAlert>
        <MudText Typo="Typo.h6" Class="mb-2">Conflicting Entries</MudText>
        <MudTable T="ConflictEntryItem" Items="_conflictEntries"
                  Hover="true" Dense="true" Striped="true" Elevation="1" Class="mb-4">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Source</MudTh>
                <MudTh>Issue Key</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Our Hours</MudTh>
                <MudTh>Timelog Hours</MudTh>
                <MudTh>Employee</MudTh>
                <MudTh>Task</MudTh>
                <MudTh>Resolution</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.WorkDate.ToString("yyyy-MM-dd")</MudTd>
                <MudTd>@context.SourceName</MudTd>
                <MudTd>@context.IssueKey</MudTd>
                <MudTd Style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    @context.Description
                </MudTd>
                <MudTd>@context.OurHours</MudTd>
                <MudTd>
                    <MudText Color="Color.Warning">@context.TimelogHours</MudText>
                </MudTd>
                <MudTd>@(context.UserDisplay ?? "—")</MudTd>
                <MudTd>@(context.TimelogTaskName ?? "—")</MudTd>
                <MudTd Style="min-width:260px">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudSelect T="ConflictResolution"
                                   Value="_conflictResolutions.GetValueOrDefault(context.Id, ConflictResolution.UseOurs)"
                                   ValueChanged="@(v => _conflictResolutions[context.Id] = v)"
                                   Dense="true" Margin="Margin.Dense"
                                   Style="min-width:160px"
                                   AnchorOrigin="Origin.BottomLeft">
                            <MudSelectItem T="ConflictResolution" Value="ConflictResolution.UseOurs">
                                Use ours (@context.OurHours h)
                            </MudSelectItem>
                            <MudSelectItem T="ConflictResolution" Value="ConflictResolution.AddToExisting">
                                Add together (@(context.OurHours + context.TimelogHours) h)
                            </MudSelectItem>
                            <MudSelectItem T="ConflictResolution" Value="ConflictResolution.SetCustom">
                                Set custom value
                            </MudSelectItem>
                        </MudSelect>
                        @if (_conflictResolutions.GetValueOrDefault(context.Id, ConflictResolution.UseOurs) == ConflictResolution.SetCustom)
                        {
                            <MudNumericField T="double?" Value="_conflictCustomHours.GetValueOrDefault(context.Id)"
                                             ValueChanged="@(v => _conflictCustomHours[context.Id] = v)"
                                             Min="0.01" Max="24" Step="0.5"
                                             Placeholder="Hours" HideSpinButtons="true"
                                             Dense="true" Margin="Margin.Dense"
                                             Style="width:70px" />
                        }
                    </MudStack>
                </MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Warning"
                               Disabled="@_resolving"
                               OnClick="@(() => ResolveConflictAsync(context))">
                        Resolve
                    </MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    @* Ready entries table *@
    @if (_readyEntries.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">Ready to Submit</MudText>
        <MudTable T="ReadyEntryItem" Items="_readyEntries"
                  MultiSelection="true"
                  @bind-SelectedItems="_selectedEntries"
                  Hover="true" Dense="true" Striped="true" Elevation="1"
                  Class="mb-4">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ReadyEntryItem, object>(x => x.WorkDate)">Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ReadyEntryItem, object>(x => x.SourceName)">Source</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ReadyEntryItem, object>(x => x.IssueKey ?? string.Empty)">Issue Key</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ReadyEntryItem, object>(x => x.Description ?? string.Empty)">Description</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ReadyEntryItem, object>(x => x.Hours)">Hours</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ReadyEntryItem, object>(x => x.UserDisplay ?? string.Empty)">Employee</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ReadyEntryItem, object>(x => x.TimelogTaskName ?? string.Empty)">Timelog Task</MudTableSortLabel></MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.WorkDate.ToString("yyyy-MM-dd")</MudTd>
                <MudTd>@context.SourceName</MudTd>
                <MudTd>@context.IssueKey</MudTd>
                <MudTd Style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    @context.Description
                </MudTd>
                <MudTd>@context.Hours</MudTd>
                <MudTd>@(context.UserDisplay ?? "—")</MudTd>
                <MudTd>@(context.TimelogTaskName ?? "—")</MudTd>
                <MudTd>
                    <MudTooltip Text="Skip — hide this entry without submitting">
                        <MudIconButton Icon="@Icons.Material.Filled.Block"
                                       Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(() => SkipOneAsync(context.Id))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
    else if (_needsTaskEntries.Count == 0 && _submittedCount == 0)
    {
        <MudAlert Severity="Severity.Info">
            No entries are ready for submission yet.
            Map some entries first using the <MudLink Href="/mapping-rules">Mapping Rules</MudLink>
            or the <MudLink Href="/">Dashboard</MudLink>.
        </MudAlert>
    }

    @* Needs task section *@
    @if (_needsTaskEntries.Count > 0)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            @_needsTaskEntries.Count entr@(_needsTaskEntries.Count == 1 ? "y is" : "ies are") mapped to a Timelog project but
            have no task assigned. Pick a task for each entry below to make them submittable.
            You may also want to update the corresponding <MudLink Href="/mapping-rules">Mapping Rules</MudLink>
            so future entries are mapped correctly.
        </MudAlert>
        <MudText Typo="Typo.h6" Class="mb-2">Needs Task Assignment</MudText>
        <MudTable T="NeedsTaskItem" Items="_needsTaskEntries"
                  Hover="true" Dense="true" Striped="true" Elevation="1" Class="mb-4">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<NeedsTaskItem, object>(x => x.WorkDate)">Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NeedsTaskItem, object>(x => x.SourceName)">Source</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NeedsTaskItem, object>(x => x.IssueKey ?? string.Empty)">Issue Key</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NeedsTaskItem, object>(x => x.Description ?? string.Empty)">Description</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NeedsTaskItem, object>(x => x.Hours)">Hours</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NeedsTaskItem, object>(x => x.UserDisplay ?? string.Empty)">Employee</MudTableSortLabel></MudTh>
                <MudTh>Project</MudTh>
                <MudTh>Assign Task</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.WorkDate.ToString("yyyy-MM-dd")</MudTd>
                <MudTd>@context.SourceName</MudTd>
                <MudTd>@context.IssueKey</MudTd>
                <MudTd Style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    @context.Description
                </MudTd>
                <MudTd>@context.Hours</MudTd>
                <MudTd>@(context.UserDisplay ?? "—")</MudTd>
                <MudTd>@context.ProjectName</MudTd>
                <MudTd Style="min-width:220px">
                    <MudSelect T="int?" Value="_taskChoices.GetValueOrDefault(context.Id)"
                               ValueChanged="@(v => _taskChoices[context.Id] = v)"
                               Dense="true" Margin="Margin.Dense"
                               Placeholder="Select task…"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var task in _projectTasks.GetValueOrDefault(context.TimelogProjectId, []))
                        {
                            <MudSelectItem T="int?" Value="@((int?)task.Id)">@task.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary"
                               Disabled="@(!_taskChoices.TryGetValue(context.Id, out var chosen) || chosen == null)"
                               OnClick="@(() => AssignTaskAsync(context.Id))">
                        Save
                    </MudButton>
                    <MudTooltip Text="Skip — hide this entry without submitting">
                        <MudIconButton Icon="@Icons.Material.Filled.Block"
                                       Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(() => SkipOneAsync(context.Id))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    @* Audit trail *@
    @if (_history.Count > 0)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6">Recent Submission History</MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Filter:</MudText>
                <MudChipSet T="SubmissionStatus" SelectionMode="SelectionMode.MultiSelection"
                            SelectedValues="_historyStatusFilter"
                            SelectedValuesChanged="@((IReadOnlyCollection<SubmissionStatus> v) => _historyStatusFilter = v)">
                    <MudChip T="SubmissionStatus" Value="SubmissionStatus.Success"      Color="Color.Success" Size="Size.Small">Success</MudChip>
                    <MudChip T="SubmissionStatus" Value="SubmissionStatus.Duplicate"    Color="Color.Info"    Size="Size.Small">Duplicate</MudChip>
                    <MudChip T="SubmissionStatus" Value="SubmissionStatus.Failed"       Color="Color.Error"   Size="Size.Small">Failed</MudChip>
                    <MudChip T="SubmissionStatus" Value="SubmissionStatus.Acknowledged" Color="Color.Default" Size="Size.Small">Acknowledged</MudChip>
                </MudChipSet>
                @if (_historyStatusFilter.Any())
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   OnClick="@(() => { _historyStatusFilter = []; })"
                                   Title="Clear status filter" />
                }
            </MudStack>
        </MudStack>
        <MudTable Items="FilteredHistory" Hover="true" Dense="true" Striped="true" Elevation="1"
                  RowsPerPage="50">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.WorkDate)">Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.UserDisplay ?? string.Empty)">Person</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.SourceName)">Source</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.IssueKey ?? string.Empty)">Issue Key</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.Description ?? string.Empty)">Description</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.Hours)">Hours</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.SubmittedAt)">Submitted At</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SubmissionHistoryItem, object>(x => x.AttemptCount)">Attempts</MudTableSortLabel></MudTh>
                <MudTh>Error</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.WorkDate.ToString("yyyy-MM-dd")</MudTd>
                <MudTd>@(context.UserDisplay ?? "—")</MudTd>
                <MudTd>@context.SourceName</MudTd>
                <MudTd>@context.IssueKey</MudTd>
                <MudTd Style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    @context.Description
                </MudTd>
                <MudTd>@context.Hours</MudTd>
                <MudTd>@context.SubmittedAt.ToLocalTime().ToString("g")</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Status switch {
                                 SubmissionStatus.Success   => Color.Success,
                                 SubmissionStatus.Duplicate => Color.Info,
                                 _                          => Color.Error
                             })">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd>@context.AttemptCount</MudTd>
                <MudTd>
                    @if (!string.IsNullOrEmpty(context.ErrorMessage))
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="max-width:220px">
                            <MudText Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;font-size:inherit">
                                @context.ErrorMessage
                            </MudText>
                            <MudTooltip Text="View full error" Placement="Placement.Left">
                                <MudIconButton Icon="@Icons.Material.Outlined.ErrorOutline"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => ShowErrorDetailAsync(context.ErrorMessage))" />
                            </MudTooltip>
                        </MudStack>
                    }
                </MudTd>
                <MudTd>
                    @if (context.Status == TimeLogger.Domain.SubmissionStatus.Failed)
                    {
                        <MudTooltip Text="Acknowledge — hide this failure from the list">
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircleOutline"
                                           Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => AcknowledgeOneAsync(context.Id))" />
                        </MudTooltip>
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    private bool _loading = true;
    private bool _submitting;
    private bool _resolving;
    private string? _accountIdFilter;
    private List<ReadyEntryItem> _readyEntries = [];
    private HashSet<ReadyEntryItem> _selectedEntries = [];
    private List<NeedsTaskItem> _needsTaskEntries = [];
    private List<ConflictEntryItem> _conflictEntries = [];
    private Dictionary<int, int?> _taskChoices = [];
    private Dictionary<int, ConflictResolution> _conflictResolutions = [];
    private Dictionary<int, double?> _conflictCustomHours = [];
    private Dictionary<int, IReadOnlyList<TimelogTaskSummary>> _projectTasks = [];
    private int _submittedCount;
    private int _failedCount;
    private List<SubmissionHistoryItem> _history = [];
    private IReadOnlyList<EmployeeSummary> _employees = [];
    private string? _myAccountId;
    private IReadOnlyCollection<SubmissionStatus> _historyStatusFilter = [];

    private IEnumerable<SubmissionHistoryItem> FilteredHistory =>
        !_historyStatusFilter.Any()
            ? _history
            : _history.Where(h => _historyStatusFilter.Contains(h.Status));

    protected override async Task OnInitializedAsync()
    {
        _employees = await SubmissionService.GetEmployeeSummariesAsync();
        await ResolveFiltersAsync();
        await LoadAsync();
    }

    private async Task ResolveFiltersAsync()
    {
        var auth = await AuthState;

        var oid = auth.User.FindFirst("oid")?.Value
            ?? auth.User.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value;
        if (oid is not null)
        {
            var appUser = await AppUserService.GetByOidAsync(oid);
            _myAccountId = appUser?.EmployeeMapping?.AtlassianAccountId;
        }

        // Default: Users see their own entries; Managers/Admins see all
        _accountIdFilter = auth.User.IsInRole("User") ? _myAccountId : null;
    }

    private async Task OnEmployeeFilterChanged(string? value)
    {
        _accountIdFilter = value;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _selectedEntries = [];
        _taskChoices = [];
        _readyEntries      = (await SubmissionService.GetReadyToSubmitAsync(_accountIdFilter)).ToList();
        _needsTaskEntries  = (await SubmissionService.GetNeedsTaskAsync(_accountIdFilter)).ToList();
        _conflictEntries   = (await SubmissionService.GetConflictsAsync(_accountIdFilter)).ToList();
        _submittedCount    = await SubmissionService.GetSubmittedCountAsync();
        _failedCount       = await SubmissionService.GetFailedCountAsync();
        _history           = (await SubmissionService.GetRecentAsync(accountIdFilter: _accountIdFilter)).ToList();
        _conflictResolutions = [];
        _conflictCustomHours = [];

        // Pre-load tasks for each distinct project that has needs-task entries
        _projectTasks = [];
        foreach (var projectId in _needsTaskEntries.Select(e => e.TimelogProjectId).Distinct())
        {
            var tasks = await TimelogDataService.GetTasksByProjectAsync(projectId, activeOnly: true);
            _projectTasks[projectId] = tasks;
        }

        _loading = false;
    }

    private async Task AssignTaskAsync(int entryId)
    {
        if (!_taskChoices.TryGetValue(entryId, out var taskId) || taskId == null) return;
        await SubmissionService.AssignTaskAsync(entryId, taskId.Value);
        Snackbar.Add("Task assigned. Entry is now ready to submit.", Severity.Success);
        await LoadAsync();
    }

    private async Task SubmitSelectedAsync()
    {
        if (!_selectedEntries.Any()) return;

        var confirmed = await DialogService.ShowMessageBox(
            "Submit Selected",
            $"Submit {_selectedEntries.Count} selected entr{(_selectedEntries.Count == 1 ? "y" : "ies")} to Timelog?",
            yesText: "Submit", cancelText: "Cancel");
        if (confirmed != true) return;

        _submitting = true;
        var ids = _selectedEntries.Select(e => e.Id).ToList();
        var result = await SubmissionService.SubmitSelectedAsync(ids);

        var parts = new List<string>();
        if (result.Succeeded  > 0) parts.Add($"{result.Succeeded} submitted");
        if (result.Duplicates > 0) parts.Add($"{result.Duplicates} already in Timelog (skipped)");
        if (result.Conflicts  > 0) parts.Add($"{result.Conflicts} conflict{(result.Conflicts == 1 ? "" : "s")} need resolution");
        if (result.Failed     > 0) parts.Add($"{result.Failed} failed");
        if (result.Skipped    > 0) parts.Add($"{result.Skipped} skipped");

        var severity = result.Failed > 0 ? Severity.Error
            : result.Conflicts > 0 ? Severity.Warning
            : Severity.Success;
        Snackbar.Add(string.Join(", ", parts) + ".", severity);

        _submitting = false;
        await LoadAsync();
    }

    private async Task SkipOneAsync(int entryId)
    {
        await SubmissionService.SkipAsync(entryId);
        await LoadAsync();
    }

    private async Task SkipSelectedAsync()
    {
        if (!_selectedEntries.Any()) return;

        var confirmed = await DialogService.ShowMessageBox(
            "Skip Selected",
            $"Hide {_selectedEntries.Count} selected entr{(_selectedEntries.Count == 1 ? "y" : "ies")} from submission? They will be marked Ignored.",
            yesText: "Skip", cancelText: "Cancel");
        if (confirmed != true) return;

        foreach (var entry in _selectedEntries.ToList())
            await SubmissionService.SkipAsync(entry.Id);

        Snackbar.Add($"Skipped {_selectedEntries.Count} entr{(_selectedEntries.Count == 1 ? "y" : "ies")}.", Severity.Info);
        await LoadAsync();
    }

    private async Task AcknowledgeOneAsync(int submittedEntryId)
    {
        await SubmissionService.AcknowledgeFailureAsync(submittedEntryId);
        await LoadAsync();
    }

    private async Task AcknowledgeAllAsync()
    {
        await SubmissionService.AcknowledgeAllFailuresAsync();
        Snackbar.Add("All failures acknowledged and hidden.", Severity.Info);
        await LoadAsync();
    }

    private async Task ShowErrorDetailAsync(string? error)
    {
        if (string.IsNullOrEmpty(error)) return;
        await DialogService.ShowMessageBox("Submission Error", error, yesText: "Close");
    }

    private async Task ResolveConflictAsync(ConflictEntryItem item)
    {
        var resolution = _conflictResolutions.GetValueOrDefault(item.Id, ConflictResolution.UseOurs);
        double? customHours = resolution == ConflictResolution.SetCustom
            ? _conflictCustomHours.GetValueOrDefault(item.Id)
            : null;

        if (resolution == ConflictResolution.SetCustom && (customHours == null || customHours <= 0))
        {
            Snackbar.Add("Enter a custom hours value greater than 0.", Severity.Warning);
            return;
        }

        _resolving = true;
        var outcome = await SubmissionService.ResolveConflictAsync(item.Id, resolution, customHours);
        _resolving = false;

        if (outcome == SubmitOutcome.Succeeded)
            Snackbar.Add($"Conflict resolved for {item.IssueKey ?? item.Description ?? "entry"}.", Severity.Success);
        else
            Snackbar.Add("Resolution failed — check logs for details.", Severity.Error);

        await LoadAsync();
    }

    private async Task SubmitAllAsync()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Submit All",
            $"Submit all {_readyEntries.Count} ready entries to Timelog?",
            yesText: "Submit All", cancelText: "Cancel");
        if (confirmed != true) return;

        _submitting = true;
        await SubmissionService.TriggerSubmitAllAsync();
        Snackbar.Add("Submission job enqueued. Refresh in a moment.", Severity.Success);
        _submitting = false;
    }
}
